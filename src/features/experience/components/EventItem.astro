---
import type { ExperienceItem } from "../data/experience.data";

interface Props {
  item: ExperienceItem;
  index: number;
  isLast: boolean;
}

const { item, index, isLast } = Astro.props;
---

<div
  class="relative pl-8 pb-10"
  data-aos="fade-up"
  data-aos-delay={index * 100}
>
  <!-- Timeline line -->
  {
    !isLast && (
      <div
        class="absolute left-[11px] top-6 bottom-0 w-px
               bg-(--border-default)"
      />
    )
  }

  <!-- Dot -->
  <div
    class:list={[
      "absolute left-0 top-1.5 w-[22px] h-[22px] rounded-full border-2 flex items-center justify-center",
      index === 2
        ? "bg-accent border-accent"
        : "bg-surface border-(--border-strong)",
    ]}
  >
    {
      index === 2 && (
        <span class="w-2 h-2 rounded-full bg-white opacity-80" />
      )
    }
  </div>

  <!-- Content -->
  <div class="ml-4">
    <span
      class="inline-block text-xs font-semibold tracking-wide
             text-secondary uppercase mb-1"
    >
      {item.period}
    </span>
    <h3 class="font-header font-bold text-lg text-primary leading-snug">
      {item.title}
      {
        item.company && (
          <span class="font-medium text-accent ml-1.5">— {item.company}</span>
        )
      }
    </h3>
    <p class="text-sm text-secondary leading-relaxed mt-2">{item.description}</p>
  </div>
</div>
