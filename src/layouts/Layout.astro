---
import "../styles/input.css";
import { Icon } from "astro-icon/components";

const year = new Date().getFullYear();

---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/webp" href="/src/assets/images/favicon/Portfolio-favicon.webp" />
    <meta name="generator" content={Astro.generator} />
    <title>Joseph Huayra — Desarrollador Full Stack</title>
    <meta
      name="description"
      content="Desarrollador Full Stack especializado en .NET, Angular, PostgreSQL y soluciones de IA con Azure OpenAI."
    />
  </head>

  <body class="bg-background text-text antialiased">

    <!-- ── Navigation ───────────────────────────────────── -->
    <header
      id="site-nav"
      class="sticky top-0 left-0 right-0 z-50
             bg-background/80 backdrop-blur-md
             border-b border-(--border-subtle)
             transition-[background-color,border-color] duration-150"
    >
      <div class="max-w-(--container-max) mx-auto px-(--container-px)">
        <div class="flex h-16 items-center justify-between">

          <!-- Logo -->
          <a
            href="#home"
            class="font-header font-bold text-xl text-primary tracking-tight"
          >
            Joseph<span class="text-accent">.</span>
          </a>

          <!-- Desktop nav -->
          <nav class="hidden md:flex items-center gap-8" aria-label="Menú principal">
            <a href="#about"      class="text-sm font-medium text-secondary hover:text-text transition-colors duration-150">Sobre Mí</a>
            <a href="#skills"     class="text-sm font-medium text-secondary hover:text-text transition-colors duration-150">Stack</a>
            <a href="#projects"   class="text-sm font-medium text-secondary hover:text-text transition-colors duration-150">Proyectos</a>
            <a href="#experience" class="text-sm font-medium text-secondary hover:text-text transition-colors duration-150">Experiencia</a>
            <a
              href="#contact"
              class="text-sm font-medium px-4 py-2 bg-primary text-white
                     rounded-lg hover:opacity-90 transition-opacity duration-150
                     shadow-sm"
            >
              Contacto
            </a>
            <button
              data-id="dark-mode-toggle"
              aria-label="Alternar modo oscuro"
              aria-pressed="false"
              class="p-1 text-secondary hover:text-primary transition-colors duration-150 cursor-pointer"
            >
              <Icon data-id="icon-moon" name="ion:moon-outline"   width={18} height={18} />
              <Icon data-id="icon-sun"  name="ion:sunny-outline"  width={18} height={18} class="hidden" />
            </button>
          </nav>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 text-secondary hover:text-text transition-colors"
            aria-label="Abrir menú"
            aria-expanded="false"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile nav -->
        <div
          id="mobile-menu"
          class="hidden md:hidden pb-5 border-t border-(--border-subtle) pt-4"
        >
          <nav class="flex flex-col gap-3" aria-label="Menú móvil">
            <a href="#about"      class="text-sm font-medium text-secondary hover:text-text transition-colors">Sobre Mí</a>
            <a href="#skills"     class="text-sm font-medium text-secondary hover:text-text transition-colors">Stack</a>
            <a href="#projects"   class="text-sm font-medium text-secondary hover:text-text transition-colors">Proyectos</a>
            <a href="#experience" class="text-sm font-medium text-secondary hover:text-text transition-colors">Experiencia</a>
            <a href="#contact"    class="text-sm font-medium text-accent">Contacto</a>
            <button
              data-id="dark-mode-toggle"
              aria-label="Alternar modo oscuro"
              aria-pressed="false"
              class="p-1 text-secondary hover:text-primary transition-colors duration-150 cursor-pointer"
            >
              <Icon data-id="icon-moon" name="ion:moon-outline"   width={18} height={18} />
              <Icon data-id="icon-sun"  name="ion:sunny-outline"  width={18} height={18} class="hidden" />
            </button>
          </nav>
        </div>
      </div>
    </header>

    <!-- ── Main content ─────────────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ── Footer ───────────────────────────────────────── -->
    <footer class="bg-primary text-white/60 border-t border-white/10">
      <div
        class="max-w-[var(--container-max)] mx-auto px-[var(--container-px)]
               py-10 flex flex-col md:flex-row justify-between items-center gap-4"
      >
        <span class="font-header font-bold text-background  text-lg">
          Joseph<span class="text-accent">.</span>
        </span>
        <p class="text-sm text-center text-background">
          &copy; {year} Joseph Dyron Huayra Puma. Todos los derechos reservados.
        </p>
        <p class="text-sm text-background/40">Construido con Astro · TailwindCSS</p>
      </div>
    </footer>
  </body>
</html>

<script>
  import "aos/dist/aos.css";
  import AOS from "aos";

  AOS.init({ once: true, duration: 500, offset: 72, easing: "ease-out" });

  // Mobile menu toggle
  const btn  = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const changeThemeBtn = document.querySelectorAll("[data-id='dark-mode-toggle']");
  const modeValue = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");

  document.addEventListener("DOMContentLoaded", () => {
    document.documentElement.classList.toggle("dark", modeValue === "dark");
    changeThemeBtn.forEach((btn) => btn.setAttribute("aria-pressed", String(modeValue === "dark")));
  });

  btn?.addEventListener("click", () => {
    const isHidden = menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isHidden));
  });

  // Close mobile menu on nav link click
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => menu.classList.add("hidden"));
  });

  const iconMoon = document.querySelectorAll("[data-id='icon-moon']");
  const iconSun  = document.querySelectorAll("[data-id='icon-sun']");

  function applyTheme(isDark: boolean) {
    document.documentElement.classList.toggle("dark", isDark);
    changeThemeBtn.forEach((btn) => btn.setAttribute("aria-pressed", String(isDark)));
    iconMoon.forEach((icon) => icon.classList.toggle("hidden", isDark));
    iconSun.forEach((icon) => icon.classList.toggle("hidden", !isDark));
  }

  // Aplicar tema guardado al cargar
  const saved = localStorage.getItem("theme");
  const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
  applyTheme(saved === "dark" || (!saved && prefersDark));

  // Toggle al hacer click
  changeThemeBtn.forEach((btn) => {
    btn.addEventListener("click", () => {
      const isDark = !document.documentElement.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      applyTheme(isDark);
    });
  });

</script>
